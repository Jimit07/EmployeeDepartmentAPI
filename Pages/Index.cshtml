@page
@{
    ViewData["Title"] = "Employee App";
}

<div class="card shadow-sm">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <h4 class="mb-0">👥 Employee Management</h4>

        @* <button class="btn btn-info mb-3" data-bind="click:runTest">
            Running Test File
        </button> *@
        @* <p data-bind="text: testMessage"></p> *@
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#employeeModal" data-bind="click: showAddDialog">
            <i class="fas fa-plus me-2"></i>Add New Employee
        </button>
    </div>
    <div class="card-body">
        <table class="table table-hover align-middle">

            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Department</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody data-bind="foreach: employees">
                <tr>
                    <td data-bind="text: name"> </td>
                    
                    <td><span class="badge bg-success" data-bind="text: departmentName"></span></td>

                    <td class="text-end">

                        <button class="btn btn-outline-info btn-sm"data-bs-toggle="modal" data-bs-target="#employeeModal" data-bind="click: $root.showEditDialog">
                            Edit
                        </button>

                        <button class="btn btn-outline-danger btn-sm" data-bind="click: $root.deleteEmployee">
                            Delete
                        </button>
                       
                  
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="employeeModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" data-bind="text: modalTitle">Add New Employee</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <input type="text" class="form-control" data-bind="value: currentEmployee.name">
                </div>
                <div class="mb-3">
                    <label class="form-label">Department</label>
                    <select class="form-select" data-bind="options: departments, optionsText: 'departmentName', optionsValue: 'dep_ID', value: currentEmployee.departmentId, optionsCaption: '--- Select ---'"></select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success" data-bind="click: saveEmployee">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/knockout/3.5.1/knockout-latest.js"></script>
    <script src="~/js/EmployeeViewModel.js"></script>
}